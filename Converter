import time
import usb_hid
from adafruit_hid.keyboard import Keyboard
from adafruit_hid.keyboard_layout_us import KeyboardLayoutUS
from adafruit_hid.keycode import Keycode
import re

# Map Duckyscript keys to Keycode
KEY_MAP = {
    "ENTER": Keycode.ENTER,
    "RETURN": Keycode.ENTER,
    "TAB": Keycode.TAB,
    "SPACE": Keycode.SPACE,
    "ESCAPE": Keycode.ESCAPE,
    "ESC": Keycode.ESCAPE,
    "DELETE": Keycode.DELETE,
    "DEL": Keycode.DELETE,
    "BACKSPACE": Keycode.BACKSPACE,
    "CAPSLOCK": Keycode.CAPS_LOCK,
    "HOME": Keycode.HOME,
    "END": Keycode.END,
    "UPARROW": Keycode.UP_ARROW,
    "DOWNARROW": Keycode.DOWN_ARROW,
    "LEFTARROW": Keycode.LEFT_ARROW,
    "RIGHTARROW": Keycode.RIGHT_ARROW,
    "CTRL": Keycode.CONTROL,
    "CONTROL": Keycode.CONTROL,
    "SHIFT": Keycode.SHIFT,
    "ALT": Keycode.ALT,
    "GUI": Keycode.GUI,
    "WINDOWS": Keycode.GUI,
    "COMMAND": Keycode.GUI,
}

keyboard = Keyboard(usb_hid.devices)
layout = KeyboardLayoutUS(keyboard)

time.sleep(3)  # Give time to focus target window

def run_dd(dd_file):
    with open(dd_file, "r") as f:
        lines = [line.rstrip() for line in f.readlines()]

    i = 0
    while i < len(lines):
        line = lines[i].strip()
        if not line or line.startswith("REM"):
            i += 1
            continue

        # DELAY
        if line.startswith("DELAY "):
            ms = int(re.findall(r"\d+", line)[0])
            time.sleep(ms / 1000)
            i += 1
            continue

        # STRING
        if line.startswith("STRING "):
            text = line[len("STRING "):]
            layout.write(text)
            i += 1
            # Check if next line is ENTER
            if i < len(lines) and lines[i].strip().upper() in ["ENTER", "RETURN"]:
                keyboard.send(Keycode.ENTER)
                i += 1
            continue

        # Single key
        if line.upper() in KEY_MAP:
            keyboard.send(KEY_MAP[line.upper()])
            i += 1
            continue

        # Key combos
        combo_keys = line.split()
        mapped_keys = [KEY_MAP.get(k.upper(), None) for k in combo_keys]
        if None not in mapped_keys and len(mapped_keys) > 1:
            keyboard.send(*mapped_keys)
            i += 1
            continue

        # REPEAT
        if line.startswith("REPEAT "):
            count = int(re.findall(r"\d+", line)[0])
            i += 1
            block_lines = []
            while i < len(lines) and not lines[i].strip().startswith("REPEAT "):
                block_lines.append(lines[i])
                i += 1
            for _ in range(count):
                for blk in block_lines:
                    # Run the block recursively
                    run_dd_line(blk)
            continue

        i += 1

def run_dd_line(line):
    """Helper to execute a single .dd line"""
    line = line.strip()
    if not line or line.startswith("REM"):
        return
    if line.startswith("DELAY "):
        ms = int(re.findall(r"\d+", line)[0])
        time.sleep(ms / 1000)
        return
    if line.startswith("STRING "):
        text = line[len("STRING "):]
        layout.write(text)
        return
    if line.upper() in KEY_MAP:
        keyboard.send(KEY_MAP[line.upper()])
        return
    combo_keys = line.split()
    mapped_keys = [KEY_MAP.get(k.upper(), None) for k in combo_keys]
    if None not in mapped_keys and len(mapped_keys) > 1:
        keyboard.send(*mapped_keys)

# Example usage
run_dd("payload.dd")
