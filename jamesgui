-- PLAYER TAB: Touch Fling Others
local touchFlingOthers = false
local touchConnection = nil

createButton(playerPage,"Toggle Touch Fling Others",function()
    touchFlingOthers = not touchFlingOthers
    status.Text = touchFlingOthers and "Touch Fling Enabled" or "Touch Fling Disabled"

    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Disconnect previous connection if it exists
    if touchConnection then
        touchConnection:Disconnect()
        touchConnection = nil
    end

    if touchFlingOthers then
        touchConnection = hrp.Touched:Connect(function(hit)
            if not touchFlingOthers then return end
            if hit and hit.Parent and hit.Parent ~= char then
                local otherHRP = hit.Parent:FindFirstChild("HumanoidRootPart")
                if otherHRP then
                    -- fling the other player
                    otherHRP.Velocity = Vector3.new(
                        math.random(-200,200),
                        200,
                        math.random(-200,200)
                    )
                end
            end
        end)
    end
end)

