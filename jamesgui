-- =========================
-- DRAG SYSTEM
-- =========================
local dragging = false
local dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    frame.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

titleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- =========================
-- FIXED SMOOTH TOGGLE
-- =========================
local visible = true
local original = {}

local function saveOriginals(obj)
    if obj:IsA("Frame") or obj:IsA("TextButton") then
        original[obj] = original[obj] or {}
        original[obj].BackgroundTransparency = obj.BackgroundTransparency
    end
    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
        original[obj] = original[obj] or {}
        original[obj].TextTransparency = obj.TextTransparency
    end
    if obj:IsA("UIStroke") then
        original[obj] = original[obj] or {}
        original[obj].Transparency = obj.Transparency
    end
    for _, child in ipairs(obj:GetChildren()) do
        saveOriginals(child)
    end
end

saveOriginals(frame)

local function tweenObject(obj, hide)
    local data = original[obj]

    if obj:IsA("Frame") or obj:IsA("TextButton") then
        TweenService:Create(obj, TweenInfo.new(0.3), {
            BackgroundTransparency = hide and 1 or (data and data.BackgroundTransparency or 0)
        }):Play()
    end

    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
        TweenService:Create(obj, TweenInfo.new(0.3), {
            TextTransparency = hide and 1 or (data and data.TextTransparency or 0)
        }):Play()
    end

    if obj:IsA("UIStroke") then
        TweenService:Create(obj, TweenInfo.new(0.3), {
            Transparency = hide and 1 or (data and data.Transparency or 0)
        }):Play()
    end

    for _, child in ipairs(obj:GetChildren()) do
        tweenObject(child, hide)
    end
end

local function toggleUI()
    visible = not visible

    if visible then
        frame.Visible = true
        tweenObject(frame, false)
    else
        tweenObject(frame, true)
        task.wait(0.3)
        frame.Visible = false
    end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.K then
        toggleUI()
    end
end)
