avatar.Parent=container

local nameLabel=Instance.new("TextLabel")
nameLabel.Size=UDim2.new(1,-45,0,40)
nameLabel.Position=UDim2.new(0,45,0,45)
nameLabel.BackgroundTransparency=1
nameLabel.Text="No player selected"
nameLabel.TextScaled=true
nameLabel.TextXAlignment=Enum.TextXAlignment.Left
nameLabel.TextColor3=Color3.new(1,1,1)
nameLabel.Parent=container

box:GetPropertyChangedSignal("Text"):Connect(function()
    local input=box.Text:lower()
    selectedPlayer=nil

    for _,v in pairs(Players:GetPlayers()) do
        if v.Name:lower():sub(1,#input)==input then selectedPlayer=v break end
    end

    if not selectedPlayer then
        for _,v in pairs(Players:GetPlayers()) do
            if v.Name:lower():find(input) then selectedPlayer=v break end
        end
    end

    if selectedPlayer then
        nameLabel.Text=selectedPlayer.Name
        avatar.Image=Players:GetUserThumbnailAsync(selectedPlayer.UserId,Enum.ThumbnailType.HeadShot,Enum.ThumbnailSize.Size100x100)
    else
        nameLabel.Text="No match"
        avatar.Image=""
    end
end)

btn.MouseButton1Click:Connect(function()
    if not selectedPlayer then status.Text="No player selected" return end

    local myHRP=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local targetHRP=selectedPlayer.Character and selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP or not targetHRP then return end

    local original=myHRP.CFrame
    status.Text="Flinging "..selectedPlayer.Name

    local bv=Instance.new("BodyVelocity")
    bv.MaxForce=Vector3.new(1e9,1e9,1e9)
    bv.Parent=myHRP

    local bav=Instance.new("BodyAngularVelocity")
    bav.MaxTorque=Vector3.new(1e9,1e9,1e9)
    bav.AngularVelocity=Vector3.new(0,9999,0)
    bav.Parent=myHRP

    local start=tick()
    while tick()-start<5 do
        RunService.Stepped:Wait()
        myHRP.CFrame=targetHRP.CFrame*CFrame.new(0,0,1)
        bv.Velocity=Vector3.new(0,600,0)
    end

    bv:Destroy()
    bav:Destroy()
    task.wait(0.1)
    myHRP.CFrame=original
    status.Text="Returned"
end)

